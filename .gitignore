tmp/
.tmp/
temp/
.temp/
**/tmp/
**/.tmp/
**/temp/
**/.temp/
tmp-*.out
uploads/*
*.zip

# Credentials and secrets
.secrets/
.credentials/
credentials/
secrets/
**/.secrets/
**/.credentials/
**/credentials/
**/secrets/
**/credential/
**/private/
**/.private/
.env
.env.*
!.env.example
*.pem
*.p12

